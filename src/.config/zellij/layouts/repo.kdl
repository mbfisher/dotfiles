layout {
    // tab-bar at top so new-tab gets the same chrome as the session
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }

    pane split_direction="vertical" {
        pane stacked=true size="33%" {
          pane command="mise" {
              args "exec" "--" "claude"
          }
        }
        pane stacked=true {
            pane command="nvim"
            pane name="shell" focus=true
        }
    }

    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}
