.DS_Store

# Brainstorming/planning artefacts written by the superpowers skills.
# These are session-local working notes — keep them out of the repo so they
# don't accumulate as commits while iterating on tasks.
docs/superpowers/

# Mutable Ghostty theme state rewritten by `ghostty-theme` on every toggle.
# Not user-portable — each machine boots into its own preferred state.
src/.config/ghostty/theme.conf

# Karabiner-generated daily backups of karabiner.json. Auto-regenerated, not
# worth versioning.
src/.config/karabiner/automatic_backups/
